# Managed by Ansible. Do not edit manually

auto lo
iface lo inet loopback

auto eth0
iface eth0 inet manual

{% for vswitch in hetzner_vswitch %}
iface eth0.{{ vswitch.vlan_id }} inet manual
auto br{{ vswitch.vlan_id }}
iface br{{ vswitch.vlan_id }} inet manual
    bridge_ports eth0.{{ vswitch.vlan_id }}
    bridge_stp off
    bridge_fd 0
    mtu {{ hetzner_vswitch_mtu }}

{% endfor %}
auto br0
iface br0 inet static
    hwaddress ether {{ ansible_facts['default_ipv4']['macaddress'] }}
    address {{ ansible_facts['default_ipv4']['address'] }}
    netmask {{ ansible_facts['default_ipv4']['netmask'] }}
    gateway {{ ansible_facts['default_ipv4']['gateway'] }}
    bridge_ports eth0
    bridge_stp off
    bridge_fd 0
    bridge_maxwait 0
{% for dns in dns_servers %}
    dns-nameservers {{ dns }}
{% endfor %}
    up route add -net {{ ansible_facts['default_ipv4']['network'] }} netmask {{ ansible_facts['default_ipv4']['netmask'] }} gw {{ ansible_facts['default_ipv4']['gateway'] }} dev br0
