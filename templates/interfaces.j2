# Managed by Ansible. Do not edit manually

auto lo
iface lo inet loopback

auto eth0
iface eth0 inet manual

auto br0
iface br0 inet static
    hwaddress ether {{ ansible_facts['default_ipv4']['macaddress'] }}
    address {{ ansible_facts['default_ipv4']['address'] }}
    netmask {{ ansible_facts['default_ipv4']['netmask'] }}
    gateway {{ ansible_facts['default_ipv4']['gateway'] }}
    bridge_ports eth0
    bridge_stp off
    bridge_fd 0
    bridge_maxwait 0
{% for dns in dns_servers %}
    dns-nameservers {{ dns }}
{% endfor %}
    up route add -net {{ ansible_facts['default_ipv4']['network'] }} netmask {{ ansible_facts['default_ipv4']['netmask'] }} gw {{ ansible_facts['default_ipv4']['gateway'] }} dev br0

iface eth0.{{ hetzner_vswitch_hosts_vlan_id }} inet manual
auto br{{ hetzner_vswitch_hosts_vlan_id }}
iface br{{ hetzner_vswitch_hosts_vlan_id }} inet manual
    address {{ private_ip }}
    netmask {{ hetzner_vswitch_netmask }}
    bridge_ports eth0.{{ hetzner_vswitch_hosts_vlan_id }}
    bridge_stp off
    bridge_fd 0
    mtu {{ hetzner_vswitch_mtu }}

iface eth0.{{ hetzner_vswitch_vms_vlan_id }} inet manual
auto br{{ hetzner_vswitch_vms_vlan_id }}
iface br{{ hetzner_vswitch_vms_vlan_id }} inet manual
    address {{ private_ip_vms }}
    netmask {{ hetzner_vswitch_vms_netmask }}
    bridge_ports eth0.{{ hetzner_vswitch_vms_vlan_id }}
    bridge_stp off
    bridge_fd 0
    bridge_vlan_aware yes
    bridge_vids 2-4094
    mtu {{ hetzner_vswitch_mtu }}
